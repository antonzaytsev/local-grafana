{
  "title": "Home",
  "uid": "home",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "timezone": "browser",
  "graphTooltip": 1,
  "time": {"from": "now-3h", "to": "now"},
  "templating": {
    "list": [
      {"name": "router", "type": "query", "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "query": "label_values(keenetic_uptime_seconds, router)", "refresh": 2, "multi": false, "current": {}},
      {"name": "instance", "type": "query", "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "query": "label_values(node_uname_info, instance)", "refresh": 2, "multi": false, "includeAll": true, "allValue": ".*", "current": {}},
      {"name": "ha_host", "type": "query", "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "query": "label_values(ha_cpu_usage_percent, host)", "refresh": 2, "multi": false, "includeAll": true, "allValue": ".*", "current": {}}
    ]
  },
  "panels": [

    {
      "id": 1,
      "title": "",
      "type": "text",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 5},
      "options": {"content": "## [Keenetic Router](/d/keenetic-router)\nRouter metrics", "mode": "markdown"},
      "transparent": true
    },
    {
      "id": 2,
      "title": "CPU",
      "type": "stat",
      "gridPos": {"x": 4, "y": 0, "w": 3, "h": 5},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}]}}},
      "targets": [{"expr": "keenetic_cpu_load_percent{router=~\"$router\"}", "legendFormat": "CPU"}]
    },
    {
      "id": 3,
      "title": "Memory",
      "type": "stat",
      "gridPos": {"x": 7, "y": 0, "w": 3, "h": 5},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}]}}},
      "targets": [{"expr": "keenetic_memory_used_percent{router=~\"$router\"}", "legendFormat": "Mem"}]
    },
    {
      "id": 4,
      "title": "CPU Over Time",
      "type": "timeseries",
      "gridPos": {"x": 10, "y": 0, "w": 14, "h": 5},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "options": {"legend": {"displayMode": "hidden"}, "tooltip": {"mode": "single"}},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"fillOpacity": 10, "lineWidth": 1}, "color": {"fixedColor": "green", "mode": "fixed"}}},
      "targets": [{"expr": "keenetic_cpu_load_percent{router=~\"$router\"}", "legendFormat": "CPU"}]
    },

    {
      "id": 10,
      "title": "",
      "type": "text",
      "gridPos": {"x": 0, "y": 5, "w": 4, "h": 5},
      "options": {"content": "## [Homelab Host](/d/homelab)\nCPU, memory, disk, network", "mode": "markdown"},
      "transparent": true
    },
    {
      "id": 11,
      "title": "CPU",
      "type": "stat",
      "gridPos": {"x": 4, "y": 5, "w": 3, "h": 5},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}]}}},
      "targets": [{"expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$instance\"}[$__rate_interval])) * 100)", "legendFormat": "CPU"}]
    },
    {
      "id": 12,
      "title": "Memory",
      "type": "stat",
      "gridPos": {"x": 7, "y": 5, "w": 3, "h": 5},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 75}]}}},
      "targets": [{"expr": "(1 - (node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"})) * 100", "legendFormat": "Mem"}]
    },
    {
      "id": 13,
      "title": "Network I/O",
      "type": "stat",
      "gridPos": {"x": 10, "y": 5, "w": 4, "h": 5},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "value_and_name"},
      "fieldConfig": {"defaults": {"unit": "Bps", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}},
      "targets": [
        {"expr": "sum(rate(node_network_receive_bytes_total{instance=~\"$instance\",device!~\"lo|veth.*|docker.*|br-.*\"}[$__rate_interval]))", "legendFormat": "RX"},
        {"expr": "sum(rate(node_network_transmit_bytes_total{instance=~\"$instance\",device!~\"lo|veth.*|docker.*|br-.*\"}[$__rate_interval]))", "legendFormat": "TX"}
      ]
    },

    {
      "id": 20,
      "title": "",
      "type": "text",
      "gridPos": {"x": 0, "y": 10, "w": 4, "h": 5},
      "options": {"content": "## [Home Assistant](/d/homeassistant)\nHA host metrics", "mode": "markdown"},
      "transparent": true
    },
    {
      "id": 21,
      "title": "CPU",
      "type": "stat",
      "gridPos": {"x": 4, "y": 10, "w": 3, "h": 5},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}]}}},
      "targets": [{"expr": "ha_cpu_usage_percent{host=~\"$ha_host\"}", "legendFormat": "CPU"}]
    },
    {
      "id": 22,
      "title": "Memory",
      "type": "stat",
      "gridPos": {"x": 7, "y": 10, "w": 3, "h": 5},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 75}]}}},
      "targets": [{"expr": "ha_memory_used_percent{host=~\"$ha_host\"}", "legendFormat": "Mem"}]
    },
    {
      "id": 23,
      "title": "Disk /",
      "type": "stat",
      "gridPos": {"x": 10, "y": 10, "w": 4, "h": 5},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}]}}},
      "targets": [{"expr": "ha_disk_used_percent{host=~\"$ha_host\"}", "legendFormat": "Disk"}]
    },

    {
      "id": 30,
      "title": "",
      "type": "text",
      "gridPos": {"x": 0, "y": 15, "w": 4, "h": 5},
      "options": {"content": "## [Claude Code](/d/claude-code)\nAI usage and cost tracking", "mode": "markdown"},
      "transparent": true
    },
    {
      "id": 31,
      "title": "Today",
      "type": "stat",
      "gridPos": {"x": 4, "y": 15, "w": 3, "h": 5},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "options": {"reduceOptions": {"calcs": ["sum"]}, "colorMode": "background", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]}}},
      "targets": [{"expr": "sum(claude_cost_usd > 0)", "legendFormat": "Cost"}],
      "timeFrom": "now/d"
    },
    {
      "id": 32,
      "title": "This Week",
      "type": "stat",
      "gridPos": {"x": 7, "y": 15, "w": 3, "h": 5},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "options": {"reduceOptions": {"calcs": ["sum"]}, "colorMode": "background", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 300}]}}},
      "targets": [{"expr": "sum(claude_cost_usd > 0)", "legendFormat": "Cost"}],
      "timeFrom": "now/w"
    },
    {
      "id": 33,
      "title": "Cost Over Time",
      "type": "timeseries",
      "gridPos": {"x": 10, "y": 15, "w": 14, "h": 5},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "options": {"legend": {"displayMode": "hidden"}, "tooltip": {"mode": "single"}},
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "custom": {"drawStyle": "bars", "fillOpacity": 50, "lineWidth": 0, "stacking": {"mode": "normal"}}, "color": {"fixedColor": "green", "mode": "fixed"}}},
      "targets": [{"expr": "sum(claude_cost_usd > 0)", "legendFormat": "Cost", "interval": "1h"}]
    },

    {
      "id": 40,
      "title": "",
      "type": "text",
      "gridPos": {"x": 0, "y": 20, "w": 4, "h": 5},
      "options": {"content": "## [Services Status](/d/services-status)\nService uptime monitoring", "mode": "markdown"},
      "transparent": true
    },
    {
      "id": 41,
      "title": "Services Up/Down",
      "type": "stat",
      "gridPos": {"x": 4, "y": 20, "w": 10, "h": 5},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "horizontal",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "targets": [{"expr": "up", "legendFormat": "{{job}}", "instant": true}]
    },
    {
      "id": 42,
      "title": "Availability %",
      "type": "bargauge",
      "gridPos": {"x": 14, "y": 20, "w": 10, "h": 5},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["mean"]},
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.95}, {"color": "green", "value": 0.99}]}
        }
      },
      "targets": [{"expr": "avg_over_time(up[$__range])", "legendFormat": "{{job}}"}]
    }
  ]
}
