{
  "title": "Server Disks",
  "uid": "server-disks",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "timezone": "browser",
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "query": "label_values(disk_smart_health_status, host)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      },
      {
        "name": "disk",
        "label": "Disk",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "query": "label_values(disk_smart_health_status{host=~\"$host\"}, disk)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Disk Health Status",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "FAILED", "color": "red"}}},
            {"type": "value", "options": {"1": {"text": "OK", "color": "green"}}}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "disk_smart_health_status{host=~\"$host\",disk=~\"$disk\"}",
          "legendFormat": "{{disk}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Disk Temperature (°C)",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 45},
              {"color": "red", "value": 55}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "disk_smart_temperature_celsius{host=~\"$host\",disk=~\"$disk\"}",
          "legendFormat": "{{disk}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Power On Hours",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      },
      "targets": [
        {
          "expr": "disk_smart_power_on_hours{host=~\"$host\",disk=~\"$disk\"}",
          "legendFormat": "{{disk}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "NVMe Life Used (%)",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 95}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "disk_smart_percentage_used{host=~\"$host\",disk=~\"$disk\"}",
          "legendFormat": "{{disk}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Temperature Over Time",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 45},
              {"color": "red", "value": 55}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "disk_smart_temperature_celsius{host=~\"$host\",disk=~\"$disk\"}",
          "legendFormat": "{{disk}} ({{model}})"
        }
      ]
    },
    {
      "id": 6,
      "title": "Reallocated Sectors",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "description": "Count of reallocated sectors. Rising values indicate deteriorating disk health.",
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 10}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "disk_smart_reallocated_sectors{host=~\"$host\",disk=~\"$disk\"}",
          "legendFormat": "{{disk}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Pending & Offline Uncorrectable Sectors",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "description": "Sectors waiting to be reallocated or that could not be recovered. Any non-zero value is concerning.",
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "disk_smart_pending_sectors{host=~\"$host\",disk=~\"$disk\"}",
          "legendFormat": "pending {{disk}}"
        },
        {
          "expr": "disk_smart_offline_uncorrectable{host=~\"$host\",disk=~\"$disk\"}",
          "legendFormat": "offline_uncorrect {{disk}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Disk Overview Table",
      "type": "table",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "disk": "Device",
              "model": "Model",
              "host": "Host",
              "Value": "Health",
              "Value 2": "Temp (°C)",
              "Value 3": "Power On (h)"
            }
          }
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Health"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {"type": "value", "options": {"0": {"text": "FAILED", "color": "red"}}},
                  {"type": "value", "options": {"1": {"text": "OK", "color": "green"}}}
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "disk_smart_health_status{host=~\"$host\",disk=~\"$disk\"}",
          "legendFormat": "{{disk}}",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "disk_smart_temperature_celsius{host=~\"$host\",disk=~\"$disk\"}",
          "legendFormat": "{{disk}}",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "disk_smart_power_on_hours{host=~\"$host\",disk=~\"$disk\"}",
          "legendFormat": "{{disk}}",
          "instant": true,
          "refId": "C"
        }
      ]
    }
  ]
}
