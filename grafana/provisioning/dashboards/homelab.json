{
  "title": "Homelab Host",
  "uid": "homelab",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Host (node-exporter)",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "victoriametrics"},
        "query": "label_values(node_uname_info, instance)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      },
      {
        "name": "disk_host",
        "label": "Host (disks)",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "victoriametrics"},
        "query": "label_values(disk_smart_health_status, host)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      },
      {
        "name": "disk",
        "label": "Disk",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "victoriametrics"},
        "query": "label_values(disk_smart_health_status{host=~\"$disk_host\"}, disk)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      }
    ]
  },
  "panels": [
    {"id": 1, "title": "CPU Usage", "type": "stat", "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}}, "targets": [{"expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$instance\"}[$__rate_interval])) * 100)", "legendFormat": "{{instance}}"}]},
    {"id": 2, "title": "Memory Usage", "type": "stat", "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 75}, {"color": "red", "value": 90}]}}}, "targets": [{"expr": "(1 - (node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"})) * 100", "legendFormat": "{{instance}}"}]},
    {"id": 3, "title": "Disk Usage (/)", "type": "stat", "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]}}}, "targets": [{"expr": "(1 - node_filesystem_avail_bytes{instance=~\"$instance\",mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{instance=~\"$instance\",mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100", "legendFormat": "{{instance}}"}]},
    {"id": 4, "title": "Network I/O", "type": "stat", "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "orientation": "horizontal"}, "fieldConfig": {"defaults": {"unit": "Bps", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}, "targets": [{"expr": "sum by (instance) (rate(node_network_receive_bytes_total{instance=~\"$instance\",device!=\"lo\"}[$__rate_interval]))", "legendFormat": "↓"}, {"expr": "sum by (instance) (rate(node_network_transmit_bytes_total{instance=~\"$instance\",device!=\"lo\"}[$__rate_interval]))", "legendFormat": "↑"}]},
    {"id": 5, "title": "CPU Over Time", "type": "timeseries", "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"tooltip": {"mode": "multi"}}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"fillOpacity": 10}}}, "targets": [{"expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$instance\"}[$__rate_interval])) * 100)", "legendFormat": "{{instance}}"}]},
    {"id": 6, "title": "Memory Over Time", "type": "timeseries", "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"tooltip": {"mode": "multi"}}, "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"fillOpacity": 10}}}, "targets": [{"expr": "node_memory_MemTotal_bytes{instance=~\"$instance\"} - node_memory_MemAvailable_bytes{instance=~\"$instance\"}", "legendFormat": "Used"}, {"expr": "node_memory_MemTotal_bytes{instance=~\"$instance\"}", "legendFormat": "Total"}]},
    {"id": 7, "title": "Network Traffic", "type": "timeseries", "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"tooltip": {"mode": "multi"}}, "fieldConfig": {"defaults": {"unit": "Bps", "custom": {"fillOpacity": 10}}}, "targets": [{"expr": "rate(node_network_receive_bytes_total{instance=~\"$instance\",device!=\"lo\"}[$__rate_interval])", "legendFormat": "↓ {{device}}"}, {"expr": "rate(node_network_transmit_bytes_total{instance=~\"$instance\",device!=\"lo\"}[$__rate_interval])", "legendFormat": "↑ {{device}}"}]},
    {"id": 8, "title": "Disk Space", "type": "bargauge", "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]}}}, "targets": [{"expr": "(1 - node_filesystem_avail_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay\"}) * 100", "legendFormat": "{{mountpoint}}"}]},
    {"id": 10, "title": "Disk Health", "type": "stat", "gridPos": {"x": 0, "y": 20, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}, "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "FAILED", "color": "red"}}}, {"type": "value", "options": {"1": {"text": "OK", "color": "green"}}}]}}, "targets": [{"expr": "disk_smart_health_status{host=~\"$disk_host\",disk=~\"$disk\"}", "legendFormat": "{{disk}}"}]},
    {"id": 11, "title": "Disk Temperature", "type": "stat", "gridPos": {"x": 6, "y": 20, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}, "fieldConfig": {"defaults": {"unit": "celsius", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 45}, {"color": "red", "value": 55}]}}}, "targets": [{"expr": "disk_smart_temperature_celsius{host=~\"$disk_host\",disk=~\"$disk\"}", "legendFormat": "{{disk}}"}]},
    {"id": 12, "title": "Disk Temperature Over Time", "type": "timeseries", "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"tooltip": {"mode": "multi"}}, "fieldConfig": {"defaults": {"unit": "celsius", "custom": {"fillOpacity": 10}}}, "targets": [{"expr": "disk_smart_temperature_celsius{host=~\"$disk_host\",disk=~\"$disk\"}", "legendFormat": "{{disk}}"}]},
    {"id": 13, "title": "SMART Attributes (Reallocated, Pending)", "type": "timeseries", "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"tooltip": {"mode": "multi"}}, "fieldConfig": {"defaults": {"custom": {"fillOpacity": 10}}}, "targets": [{"expr": "disk_smart_reallocated_sectors{host=~\"$disk_host\",disk=~\"$disk\"}", "legendFormat": "reallocated {{disk}}"}, {"expr": "disk_smart_pending_sectors{host=~\"$disk_host\",disk=~\"$disk\"}", "legendFormat": "pending {{disk}}"}]}
  ]
}
