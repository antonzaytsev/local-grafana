{
  "title": "Homelab Host",
  "uid": "homelab",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "graphTooltip": 1,
  "time": {"from": "now-6h", "to": "now"},
  "templating": {
    "list": [
      {"name": "instance", "label": "Host (node-exporter)", "type": "query", "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "query": "label_values(node_uname_info, instance)", "refresh": 2, "multi": false, "includeAll": true, "allValue": ".*", "current": {}},
      {"name": "disk_host", "label": "Host (disks)", "type": "query", "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "query": "label_values(disk_smart_health_status, host)", "refresh": 2, "multi": false, "includeAll": true, "allValue": ".*", "current": {}},
      {"name": "disk", "label": "Disk", "type": "query", "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "query": "label_values(disk_smart_health_status{host=~\"$disk_host\"}, disk)", "refresh": 2, "multi": true, "includeAll": true, "allValue": ".*", "current": {}}
    ]
  },
  "panels": [
    {"id": 1, "title": "Host overview", "type": "row", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}, "collapsed": false},
    {"id": 2, "title": "CPU Usage", "type": "stat", "gridPos": {"x": 0, "y": 1, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}}, "targets": [{"expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$instance\"}[$__rate_interval])) * 100)", "legendFormat": "{{instance}}"}]},
    {"id": 3, "title": "Memory Usage", "type": "stat", "gridPos": {"x": 6, "y": 1, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 75}, {"color": "red", "value": 90}]}}}, "targets": [{"expr": "(1 - (node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"})) * 100", "legendFormat": "{{instance}}"}]},
    {"id": 4, "title": "Disk Usage (/)", "type": "stat", "gridPos": {"x": 12, "y": 1, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]}}}, "targets": [{"expr": "(1 - node_filesystem_avail_bytes{instance=~\"$instance\",mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{instance=~\"$instance\",mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100", "legendFormat": "{{instance}}"}]},
    {"id": 5, "title": "Network I/O", "type": "stat", "gridPos": {"x": 18, "y": 1, "w": 6, "h": 4}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "orientation": "horizontal"}, "fieldConfig": {"defaults": {"unit": "Bps", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}, "targets": [{"expr": "sum by (instance) (rate(node_network_receive_bytes_total{instance=~\"$instance\",device!=\"lo\"}[$__rate_interval]))", "legendFormat": "↓"}, {"expr": "sum by (instance) (rate(node_network_transmit_bytes_total{instance=~\"$instance\",device!=\"lo\"}[$__rate_interval]))", "legendFormat": "↑"}]},
    {"id": 6, "title": "CPU Over Time", "type": "timeseries", "gridPos": {"x": 0, "y": 5, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"tooltip": {"mode": "multi"}}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"fillOpacity": 10}}}, "targets": [{"expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$instance\"}[$__rate_interval])) * 100)", "legendFormat": "{{instance}}"}]},
    {"id": 7, "title": "Memory Over Time", "type": "timeseries", "gridPos": {"x": 12, "y": 5, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"tooltip": {"mode": "multi"}}, "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"fillOpacity": 10}}}, "targets": [{"expr": "node_memory_MemTotal_bytes{instance=~\"$instance\"} - node_memory_MemAvailable_bytes{instance=~\"$instance\"}", "legendFormat": "Used"}, {"expr": "node_memory_MemTotal_bytes{instance=~\"$instance\"}", "legendFormat": "Total"}]},
    {"id": 8, "title": "Network Traffic", "type": "timeseries", "gridPos": {"x": 0, "y": 13, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"tooltip": {"mode": "multi"}}, "fieldConfig": {"defaults": {"unit": "Bps", "custom": {"fillOpacity": 10}}}, "targets": [{"expr": "rate(node_network_receive_bytes_total{instance=~\"$instance\",device!=\"lo\"}[$__rate_interval])", "legendFormat": "↓ {{device}}"}, {"expr": "rate(node_network_transmit_bytes_total{instance=~\"$instance\",device!=\"lo\"}[$__rate_interval])", "legendFormat": "↑ {{device}}"}]},
    {"id": 9, "title": "Disk Space", "type": "bargauge", "gridPos": {"x": 12, "y": 13, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}, "displayMode": "gradient"}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]}}}, "targets": [{"expr": "(1 - node_filesystem_avail_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay\"}) * 100", "legendFormat": "{{mountpoint}}"}]},
    {"id": 20, "title": "{{disk}}", "type": "row", "gridPos": {"x": 0, "y": 21, "w": 24, "h": 1}, "collapsed": false, "repeat": "disk"},
    {"id": 21, "title": "Health", "type": "stat", "gridPos": {"x": 0, "y": 22, "w": 4, "h": 4}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}, "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "FAILED", "color": "red"}}}, {"type": "value", "options": {"1": {"text": "OK", "color": "green"}}}]}}, "targets": [{"expr": "disk_smart_health_status{host=~\"$disk_host\",disk=~\"$disk\"}", "legendFormat": "{{disk}}"}]
    },
    {"id": 22, "title": "Temperature (°C)", "type": "stat", "gridPos": {"x": 4, "y": 22, "w": 4, "h": 4}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}, "fieldConfig": {"defaults": {"unit": "celsius", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 45}, {"color": "red", "value": 55}]}}}, "targets": [{"expr": "disk_smart_temperature_celsius{host=~\"$disk_host\",disk=~\"$disk\"} and disk_smart_temperature_celsius < 100", "legendFormat": "{{disk}}"}]
    },
    {"id": 23, "title": "Power On Hours", "type": "stat", "gridPos": {"x": 8, "y": 22, "w": 4, "h": 4}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}, "fieldConfig": {"defaults": {}}, "targets": [{"expr": "disk_smart_power_on_hours{host=~\"$disk_host\",disk=~\"$disk\"} and disk_smart_power_on_hours < 1e7", "legendFormat": "{{disk}}"}]
    },
    {"id": 24, "title": "NVMe Wear %", "type": "stat", "gridPos": {"x": 12, "y": 22, "w": 4, "h": 4}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 80}, {"color": "red", "value": 95}]}}}, "targets": [{"expr": "disk_smart_percentage_used{host=~\"$disk_host\",disk=~\"$disk\"}", "legendFormat": "{{disk}}"}]
    },
    {"id": 25, "title": "Temperature Over Time", "type": "timeseries", "gridPos": {"x": 0, "y": 26, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"tooltip": {"mode": "multi"}}, "fieldConfig": {"defaults": {"unit": "celsius", "min": 0, "max": 100, "custom": {"fillOpacity": 10}}}, "targets": [{"expr": "disk_smart_temperature_celsius{host=~\"$disk_host\",disk=~\"$disk\"} and disk_smart_temperature_celsius < 100", "legendFormat": "{{disk}}"}]
    },
    {"id": 26, "title": "Reallocated & Pending Sectors", "type": "timeseries", "gridPos": {"x": 12, "y": 26, "w": 12, "h": 8}, "datasource": {"type": "prometheus", "uid": "victoriametrics"}, "options": {"tooltip": {"mode": "multi"}}, "fieldConfig": {"defaults": {"custom": {"fillOpacity": 10}}}, "targets": [{"expr": "disk_smart_reallocated_sectors{host=~\"$disk_host\",disk=~\"$disk\"}", "legendFormat": "reallocated {{disk}}"}, {"expr": "disk_smart_pending_sectors{host=~\"$disk_host\",disk=~\"$disk\"}", "legendFormat": "pending {{disk}}"}]
    }
  ]
}
